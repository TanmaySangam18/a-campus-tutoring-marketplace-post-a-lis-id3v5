"use client";                                                                   
                                                                                
                                                                                
                                                                                
import { useCallback, useEffect, useState } from "react";                       
                                                                                
import type { FormEvent, ReactNode } from "react";                              
                                                                                
                                                                                
                                                                                
type Slot = {                                                                   
                                                                                
  id: string;                                                                   
                                                                                
  label: string;                                                                
                                                                                
  booked: boolean;                                                              
                                                                                
  bookedBy: string | null;                                                      
                                                                                
};                                                                              
                                                                                
                                                                                
                                                                                
type Listing = {                                                                
                                                                                
  id: string;                                                                   
                                                                                
  subject: string;                                                              
                                                                                
