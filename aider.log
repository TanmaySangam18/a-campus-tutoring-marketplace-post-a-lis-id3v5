border-zinc-200 px-3 py-1.5 text-sm text-zinc-900 outline-none transition       
duration-150 focus:border-indigo-500 focus-visible:outline                      
focus-visible:outline-2 focus-visible:outline-offset-2                          
focus-visible:outline-indigo-600"                                               
                                                                                
                                    />                                          
                                                                                
                                    {bookingError && (                          
                                                                                
